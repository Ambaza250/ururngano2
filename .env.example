# Firebase Admin SDK configuration
# Create a service account in Firebase/GCP and download the JSON key.
# Set GOOGLE_APPLICATION_CREDENTIALS to the absolute (or relative) path of that JSON file.
# Example (Windows): GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"

GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"

# Optional override (default already set in code to admin@urungano.com)
ADMIN_EMAIL="admin@urungano.com"

# Notes:
# - This backend endpoint will fail with: "Unable to detect a Project Id"
#   if GOOGLE_APPLICATION_CREDENTIALS is missing/invalid.

