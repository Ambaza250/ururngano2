# Firebase Admin service account configuration
# REQUIRED for therapist creation endpoint.
# Create this file based on your downloaded Firebase Admin service account JSON.

# Option A (recommended): path to the service account JSON file.
# Example: GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"
GOOGLE_APPLICATION_CREDENTIALS="./serviceAccountKey.json"

# Only admin@urungano.com is allowed to create therapists.
ADMIN_EMAIL="admin@urungano.com"

FIREBASE_PROJECT_ID=urungano-chat-50d62